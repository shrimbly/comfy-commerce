# ── Broker ──────────────────────────────────────────────────────────
# PORT=4000
# HOST=127.0.0.1            # bind to localhost by default; put a reverse proxy in front for remote access.
#                           # DNS-rebinding guard: requests whose Host header is neither localhost nor the
#                           # APP_URL/WEB_ORIGIN host are rejected (403) — an exposed/proxied deployment must
#                           # set APP_URL (or WEB_ORIGIN) to its public origin.
# DATA_DIR=./data           # SQLite db, encryption key, edited-image assets
# APP_URL=http://localhost:4000   # base URL of the broker; localhost is fine — publishes push
#                                 # image bytes to Shopify via staged uploads, no tunnel needed
# WEB_ORIGIN=http://localhost:5173   # in production (SERVE_WEB=1) this defaults to the broker's own origin

# SERVE_WEB=1               # broker serves the built web UI (web/dist) on its own port — single-process prod
                            # (`pnpm build && pnpm start`). Implied when NODE_ENV=production.
# WEB_DIST=                 # explicit path to the built web UI; auto-probed next to the repo when unset
# RUN_CONCURRENCY=2         # max runs executing at once (guards local ComfyUI / cloud spend)
# WORKFLOW_BODY_LIMIT=10485760   # max workflow-graph upload size in bytes (10 MB)
# SHUTDOWN_TIMEOUT_MS=10000      # grace period before a SIGINT/SIGTERM force-exits

# BROKER_API_TOKEN=         # OPTIONAL. When set, ALL /api/* calls — the studio and headless callers — must
                            # send `Authorization: Bearer <token>`. The studio prompts for the token once and
                            # keeps it in the browser; the desktop app manages its own token automatically.
                            # Unset (default) = broker is open — fine for the localhost-only single-operator case.
# OPEN_BROWSER=0           # set to 0/false to stop `pnpm start` auto-opening the studio in your browser
# LOG_LEVEL=warn           # warn (default) keeps output clean; use info/debug for verbose request logs

# ── Shopify (leave unset for demo/mock mode) ───────────────────────
# Create an app in the Shopify Partner dashboard (or a custom app), set the
# allowed redirect URL to {APP_URL}/api/connect/shopify/callback —
# http://localhost:4000/... works for development.
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# SHOPIFY_SCOPES=read_products,write_products,write_files
# SHOPIFY_API_VERSION=2026-01      # keep current — Shopify supports each version ~12 months
# SHOPIFY_MEDIA_READY_TIMEOUT_MS=60000        # wait for image ingestion to reach READY
# SHOPIFY_MEDIA_READY_VIDEO_TIMEOUT_MS=300000 # video transcoding is slow — allow up to 5 min

# ── Token encryption (optional — auto-generated into DATA_DIR if unset) ──
# TOKEN_ENCRYPTION_KEY=<64 hex chars>

# ── Generation engines ──────────────────────────────────────────────
# COMFY_LOCAL_URL=http://127.0.0.1:8188
# COMFY_JOB_TIMEOUT_MS=900000      # local/remote ComfyUI job ceiling (ms); the engine is interrupted on timeout — raise for long video runs
# COMFY_LOCAL_CHECKPOINT=          # optional; built-ins default to the first installed checkpoint
# COMFY_REMOTE_URL=                # optional seed for the Remote ComfyUI engine (a ComfyUI on another machine); the Connectors-page value wins
# COMFY_REMOTE_CHECKPOINT=         # optional; built-ins default to the first installed checkpoint
# COMFY_CLOUD_API_URL=https://cloud.comfy.org
# COMFY_CLOUD_API_KEY=             # optional seed; also settable in the UI (Connectors → Comfy Cloud → Configure), where the saved value wins. From https://platform.comfy.org → API keys
# COMFY_CLOUD_CHECKPOINT=
